{
  "name": "bota-dev-blogs.github.io",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "ASTRO_TELEMETRY_DISABLED=1 astro dev",
    "build": "ASTRO_TELEMETRY_DISABLED=1 astro build",
    "preview": "ASTRO_TELEMETRY_DISABLED=1 astro preview",
    "gif": "node scripts/generate-blog-gif.mjs",
    "gif:doctor": "node scripts/gif-doctor.mjs",
    "gif:check": "node scripts/check-gif-assets.mjs",
    "gif:clean": "node scripts/clean-gif-workspace.mjs",
    "export:bota": "node scripts/export-bota-post.mjs",
    "export:bota:all": "node scripts/export-bota-post.mjs --all",
    "export:bota:site": "node scripts/export-bota-site.mjs",
    "gif:setup": "npm install --prefix AI/ai-gif-pipeline-1 && npm install --prefix AI/ai-gif-pipeline-2",
    "gif:setup:1": "npm install --prefix AI/ai-gif-pipeline-1",
    "gif:setup:2": "npm install --prefix AI/ai-gif-pipeline-2",
    "featured:images": "node scripts/generate-featured-images.mjs"
  },
  "dependencies": {
    "@astrojs/mdx": "latest",
    "astro": "latest"
  },
  "devDependencies": {}
}
