{
  "title": "Paper method overview",
  "subtitle": "A compact animated technical diagram",
  "width": 1080,
  "height": 650,
  "duration": 6,
  "fps": 15,
  "theme": "light",
  "nodes": [
    {
      "id": "input",
      "kind": "input",
      "label": "Input",
      "description": "audio / image / text",
      "x": 90,
      "y": 250,
      "width": 210,
      "height": 120
    },
    {
      "id": "method",
      "kind": "method",
      "label": "Proposed method",
      "description": "core module",
      "x": 435,
      "y": 250,
      "width": 250,
      "height": 120
    },
    {
      "id": "output",
      "kind": "output",
      "label": "Output",
      "description": "prediction / result",
      "x": 820,
      "y": 250,
      "width": 210,
      "height": 120
    }
  ],
  "edges": [
    { "id": "edge-input-method", "from": "input", "to": "method", "label": "features" },
    { "id": "edge-method-output", "from": "method", "to": "output", "label": "prediction" }
  ],
  "animation": [
    { "target": "edge-input-method", "effect": "flow", "at": 0.0, "loop": true, "speed": 24 },
    { "target": "method", "effect": "highlight", "at": 0.0, "loop": true, "period": 1.8 },
    { "target": "edge-method-output", "effect": "flow", "at": 1.0, "loop": true, "speed": 24 }
  ]
}
