# Copy this file to .env in the same folder and fill one provider.
# Do not commit .env.

# OpenAI-compatible or ccswitch routing
LLM_PROVIDER=openai
OPENAI_API_KEY=replace-me
OPENAI_URL=https://api.openai.com
OPENAI_MODEL=gpt-5.5

