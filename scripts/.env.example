# Do not paste a real key into this committed example file.
# The program reads OPENAI_API_KEY from your shell environment.
OPENAI_API_KEY=replace_me_locally

# Optional. The default is the cost-sensitive planning model.
OPENAI_MODEL=gpt-5.6-luna

# Optional. Featured-image generation uses GPT Image models, not OPENAI_MODEL.
OPENAI_IMAGE_MODEL=gpt-image-2

# Optional. Use a verified OpenAI-compatible Image API base URL.
# Prefer this image-specific value when your text LLM proxy is not the same endpoint.
# OPENAI_IMAGE_URL=https://api.openai.com/v1
# OPENAI_BASE_URL=https://api.openai.com/v1

# DeepSeek alternative. If this is set and LLM_PROVIDER is omitted, DeepSeek is selected.
DEEPSEEK_API_KEY=replace_me_locally
LLM_PROVIDER=deepseek
LLM_MODEL=deepseek-v4-flash
DEEPSEEK_BASE_URL=https://api.deepseek.com
